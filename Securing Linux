sudo apt install unattended-upgrades
sudo dpkg-reconfigure --priority=low unattended-upgrades

sudo adduser <USERNAME>
sudo usermod -aG sudo <USERNAME>

mkdir ~/.ssh && sudo chmod 700 ~/.ssh

WINDOWS:
ssh-keygen -b 4096
scp $env:USERPROFILE/.ssh/id_rsa.pub <USER>@<IP-ADDRESS>:~/.ssh/authorized_keys

LINUX:
sudo nano /etc/ssh/sshd_config
	Port ###
	AddressFamily inet
	PermitRootLogin no
	PasswordAuthentication no
sudo systemctl restart sshd

sudo systemctl stop ssh.service
sudo systemctl disable ssh.service
sudo systemctl enable ssh.socket

sudo systemctl daemon-reload

Retart ssh.socket service:

sudo systemctl restart ssh.socket

sudo apt install ufw
sudo ufw allow <DEFINED IN /etc/ssh/sshd_config>
sudo ufw enable
sudo nano /etc/ufw/before.rules
	# ok icmp codes for INPUT
	-A ufw-before-input -p icmp --icmp-type echo-request -j DROP
sudo ufw reload

[PASWWORD HASHING]

openssl passwd <algorithm> <yourpassword>

<algorithm>
MD5 = -1
SHA256 = -5
SHA512 = -6
APR1 = -apr1
AIX MD5 = -aixmd5
